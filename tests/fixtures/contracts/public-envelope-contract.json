      "searchSkillIds": [],
      "lookupBundle": null,
      "lookupWarningCodes": [
        "skill_disabled"
      ],
      "lookupWarningOrigins": [
        "request"
      ],
      "recommendationIds": [],
      "explainRecommendation": null,
      "explainWarningCodes": [
        "skill_disabled"
      ],
      "explainWarningOrigins": [
        "request"
      ]
    },
    "warnings": {
      "search": [],
      "searchExplain": [],
      "recommend": [],
      "recommendExplain": [],
      "telemetry": [],
      "telemetryExplain": [],
      "disabledList": [],
      "disabledSearch": [],
      "disabledRecommend": []

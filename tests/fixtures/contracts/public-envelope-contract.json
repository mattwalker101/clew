    "defaultSurfaces": {
      "searchKeys": [
        "query",
        "skills",
        "warnings"
      ],
      "recommendKeys": [
        "query",
        "recommendations",
        "warnings"
      ],
      "telemetryKeys": [
        "dbPath",
        "skills",
        "warnings",
        "telemetry"
      ]
    },
    "analysisSurfaces": {
      "searchExplainKeys": [
        "query",
        "analysis",
        "warnings"
      ],
      "recommendExplainKeys": [
        "query",
        "analysis",
        "warnings"
      ],
      "telemetryExplainKeys": [
        "dbPath",
        "skills",
        "warnings",
        "analysis"
      ]
    },
    "enabledReads": {
      "searchSkillIds": [
        "typescript-core"
      ],
      "searchAnalysisMatchIds": [
        "typescript-core"
      ],
      "recommendationIds": [
        "typescript-core"
      ],
      "recommendationAnalysisIds": [
        "typescript-core"
      ],

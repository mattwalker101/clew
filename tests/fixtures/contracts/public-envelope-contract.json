        "analysis",
        "warnings"
      ],
      "searchAnalysisKeys": [
        "query",
        "analysis",
        "warnings"
      ],
      "recommendationAnalysisKeys": [
        "query",
        "analysis",
        "warnings"
      ],
      "telemetryAnalysisKeys": [
        "analysis",
        "warnings"
      ]
    },
    "enabledReads": {
